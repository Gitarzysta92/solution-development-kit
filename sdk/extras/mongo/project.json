{
  "name": "sdk-extras-mongo",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "sdk/extras/mongo/src",
  "tags": ["type:extras", "scope:mongo"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/sdk/extras/mongo"],
      "options": {
        "command": "tsc --build sdk/extras/mongo/tsconfig.lib.json"
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "sdk/extras/mongo/jest.config.ts"
      }
    }
  }
}
